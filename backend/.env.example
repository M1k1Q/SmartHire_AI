# Environment variables for Smart Recruitment Platform
# Copy this file to .env and fill in your values

FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=another-very-long-random-jwt-secret
JWT_EXPIRES_HOURS=24

MONGO_URI=mongodb://localhost:27017/recruitment_db
MONGO_DBNAME=recruitment_db

UPLOAD_FOLDER=uploads
MODELS_FOLDER=ml_models

CORS_ORIGINS=http://localhost:3000

LOG_LEVEL=INFO
LOG_FILE=recruitment.log
